---
import { initLocale, getLocale, t } from '../i18n/utils';

const locale = initLocale();
---

<!doctype html>
<html lang="en" data-lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Infinite — Developer portfolio. AI‑powered web apps, creative tools, and open‑source projects." />
    <!-- Blocking script: set theme BEFORE first paint to prevent flash -->
    <script is:inline>
      (function(){var t=localStorage.getItem('theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();
    </script>
    <meta name="author" content="Sami Räisänen" />

    <!-- Open Graph -->
    <meta property="og:title" content="Sami Räisänen — Developer Portfolio" />
    <meta property="og:description" content="Full‑stack developer crafting AI‑powered experiences. Explore my projects." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://samppafin.github.io/Infinite/" />
    <meta property="og:image" content="https://samppafin.github.io/Infinite/og-image.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/Infinite/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <title>Sami Räisänen — Developer Portfolio</title>
  </head>
  <body>
    <slot />

    <script is:inline>
      // Init locale from localStorage
      const storedLocale = localStorage.getItem('locale') || 'en';
      document.documentElement.setAttribute('data-lang', storedLocale);

      // Init theme from localStorage
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    </script>

    <script>
      import { initScrollReveal } from '../components/ScrollReveal.js';

      // Initialize scroll reveal after DOM is ready
      document.addEventListener('DOMContentLoaded', () => {
        initScrollReveal();
      });

      // Re-initialize on Astro page swaps
      document.addEventListener('astro:page-load', () => {
        initScrollReveal();
      });
    </script>
  </body>
</html>
