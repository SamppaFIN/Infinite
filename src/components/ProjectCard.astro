---
import { t, getLocale } from '../i18n/utils';
import type { EnrichedProject } from '../lib/projects';

interface Props {
  project: EnrichedProject;
}

const { project } = Astro.props;
const locale = getLocale();
const title = project.title[locale as 'en' | 'fi'] ?? project.title.en;
const description = project.description[locale as 'en' | 'fi'] ?? project.description.en;
const imageSrc = project.image || 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=800&auto=format&fit=crop';
const hasLinks = project.demoUrl || project.repoUrl;
---

<article
  class="project-card group relative rounded-2xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] transition-all duration-500 hover:shadow-[0_0_40px_rgba(99,102,241,0.15)] cursor-pointer reveal"
  data-project-slug={project.slug}
>
  <!-- Image -->
  <div class="relative h-48 overflow-hidden">
    <img
      src={imageSrc}
      alt={title}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-surface)] via-transparent to-transparent"></div>

    <!-- GitHub stats overlay -->
    {project.github && (
      <div class="absolute top-3 right-3 flex items-center gap-3 text-xs text-white/80 font-mono bg-black/40 backdrop-blur-sm rounded-full px-2.5 py-1">
        <span class="flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {project.github.stars}
        </span>
        <span class="flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 3v18l6-3 6 3V3H6z"/></svg>
          {project.github.forks}
        </span>
        {project.github.language && (
          <span class="flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-[var(--color-accent)]"></span>
            {project.github.language}
          </span>
        )}
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-5">
    <h3 class="text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-glow)] transition-colors duration-300">
      {title}
    </h3>
    <p class="mt-2 text-sm text-[var(--color-text-secondary)] line-clamp-2 leading-relaxed">
      {description}
    </p>

    <!-- Tech badges -->
    <div class="mt-3 flex flex-wrap gap-1.5">
      {project.tags.slice(0, 4).map((tag) => (
        <span class="tech-badge">{tag}</span>
      ))}
      {project.tags.length > 4 && (
        <span class="tech-badge">+{project.tags.length - 4}</span>
      )}
    </div>

    <!-- Links -->
    {hasLinks && (
      <div class="mt-4 flex gap-4 text-sm font-medium">
        {project.demoUrl && (
          <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:text-[var(--color-accent-glow)] transition-colors">
            {t('modal.demo')}
          </a>
        )}
        {project.repoUrl && (
          <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] transition-colors">
            {t('modal.repo')}
          </a>
        )}
      </div>
    )}
  </div>
</article>
